# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional image storage settings
SUPABASE_IMAGES_BUCKET=generated-images
SUPABASE_IMAGE_SIGNED_URL_TTL_SECONDS=1200

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Image providers (at least one required if includeImages is enabled) ─────
# fal.ai — default provider (FLUX/dev + FLUX Kontext for reference images)
FAL_KEY=your-fal-key
# OpenAI — uses GPT Image 2; set to enable the OpenAI provider option
OPENAI_API_KEY=sk-...
# Google Gemini — uses Gemini 3 Pro Image; set to enable the Gemini provider option
# Note: returns base64 data URIs; storage layer handles conversion
GEMINI_API_KEY=your-gemini-api-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Checkout Prices for subscriptions. Configure the matching Products
# in Stripe with tax code txcd_10105001 and tax-exclusive USD Prices.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_FAMILY_MONTHLY=price_...
STRIPE_PRICE_FAMILY_YEARLY=price_...
# Enable only after Stripe Tax settings and registrations are configured.
STRIPE_AUTOMATIC_TAX_ENABLED=false

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── Twilio (SMS + 2FA) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1...
TWILIO_VERIFY_SERVICE_SID=VA...
TWILIO_WEBHOOK_SECRET=your-webhook-secret

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Sentry ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/000000
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional emergency fallback while migrating to platform_admins table.
ADMIN_USER_IDS=uuid1,uuid2
